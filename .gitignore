# ── Rust / Cargo ─────────────────────────────────────────────
/target/
**/target/
**/*.rs.bk
*.pdb
# Binary application — keep Cargo.lock in history; matches workspace layout
!Cargo.lock

# ── Rust coverage / profiling ────────────────────────────────
*.profraw
*.profdata
flamegraph.svg
perf.data
perf.data.old

# ── JS bridges (bun/tsc output + deps) ───────────────────────
crates/core/*/bridge/dist/
apps/*/frontend/dist/
# Catch every node_modules anywhere in the tree: repo root, each
# crate's bridge dir, each Tauri app's frontend dir. Previously the
# two scoped globs only covered `crates/core/*/bridge/node_modules/`
# and `apps/*/frontend/node_modules/`, missing the repo-root
# `/node_modules/` and the current Tauri layout
# `apps/flowstate/node_modules/` — those started leaking into
# editor diff views (vitest / npx drop caches there).
**/node_modules/
**/*.tsbuildinfo

# ── Build artifacts ──────────────────────────────────────────
*.exe
*.dll
*.so
*.dylib

# ── Environment / secrets ────────────────────────────────────
.env
.env.*
!.env.example

# ── Test output ──────────────────────────────────────────────
coverage/
.nyc_output/

# ── Editor / IDE ─────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.iml
*.sw?
*.swp
*.swo
.history/
*~

# ── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Project-specific ─────────────────────────────────────────
.zenui/

# ── Cross-compile tooling caches ─────────────────────────────
# `cargo-xwin` (used by `just build-windows`) caches MSVC SDK
# downloads under ~/.xwin globally, but it also drops a project-
# local `.xwin-cache/` for dl + unpack scratch when the workspace
# becomes its CWD. Build artifact, not source.
.xwin-cache/
