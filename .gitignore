# ── Rust / Cargo ─────────────────────────────────────────────
/target/
**/target/
**/*.rs.bk
*.pdb
# Binary application — keep Cargo.lock in history; matches workspace layout
!Cargo.lock

# ── Rust coverage / profiling ────────────────────────────────
*.profraw
*.profdata
flamegraph.svg
perf.data
perf.data.old

# ── JS bridges (bun/tsc output + deps) ───────────────────────
crates/core/*/bridge/dist/
crates/core/*/bridge/node_modules/
apps/*/frontend/dist/
apps/*/frontend/node_modules/
**/*.tsbuildinfo

# ── Build artifacts ──────────────────────────────────────────
*.exe
*.dll
*.so
*.dylib

# ── Environment / secrets ────────────────────────────────────
.env
.env.*
!.env.example

# ── Test output ──────────────────────────────────────────────
coverage/
.nyc_output/

# ── Editor / IDE ─────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.iml
*.sw?
*.swp
*.swo
.history/
*~

# ── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Project-specific ─────────────────────────────────────────
.zenui/
