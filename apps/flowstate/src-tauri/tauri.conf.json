{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "flowstate",
  "version": "0.2.20",
  "identifier": "com.seg4lt.flowstate",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "flowstate",
        "width": 1296,
        "height": 810,
        "minWidth": 400,
        "minHeight": 400,
        "center": true,
        "backgroundColor": "#252525",
        "dragDropEnabled": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/seg4lt/flowstate/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRFNUE0RkNDNjI1RkJDQzkKUldUSnZGOWl6RTlhVG5NMi91VGtTSDJydldoNFhydGl6Lzk1R3VsUlA0T09vTXA2Wmt4QzBTbVEK"
    }
  }
}
