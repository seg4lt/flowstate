{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window and thread popouts (label `thread-<session_id>`, opened via the `popout_thread` command)",
  "windows": ["main", "thread-*"],
  "permissions": [
    "core:app:default",
    "core:event:default",
    "core:path:default",
    "core:webview:default",
    "core:webview:allow-set-webview-zoom",
    "clipboard-manager:allow-write-text",
    "clipboard-manager:allow-write-image",
    "core:window:default",
    "core:window:allow-set-badge-count",
    "core:window:allow-start-dragging",
    "opener:default",
    "dialog:default",
    "updater:default",
    "process:default",
    "process:allow-restart"
  ]
}
